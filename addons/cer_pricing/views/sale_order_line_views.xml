<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_sale_order_form_inherit_cer_pricing_lines" model="ir.ui.view">
    <field name="name">sale.order.form.inherit.cer.pricing.lines</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">

      <!-- 1) DESCRIPCIÓN -->
      <xpath expr="//field[@name='order_line']//*[self::list]//field[@name='product_id']" position="attributes">
        <attribute name="string">DESCRIPCIÓN</attribute>
      </xpath>

      <!-- 2) Ocultar la cantidad (qty): en CER se trabaja con personas + duración -->
      <xpath expr="//field[@name='order_line']//*[self::list]//field[@name='product_uom_qty']" position="attributes">
        <attribute name="invisible">1</attribute>
        <attribute name="optional">hide</attribute>
      </xpath>

      <!-- 3) Insertar columnas CER: Personas + Noches/Días -->
      <xpath expr="//field[@name='order_line']//*[self::list]//field[@name='product_id']" position="after">
        <field name="cer_participants" string="CANTIDAD DE PERSONAS" optional="show"/>
        <field name="cer_duration_display" string="NOCHES Y/O DÍAS" optional="show" readonly="1"/>
      </xpath>

      <!-- 4) Precio unitario (sin IVA): reemplazar el estándar -->
      <xpath expr="//field[@name='order_line']//*[self::list]//field[@name='price_unit']" position="replace">
        <field name="cer_price_unit_excl_tax" string="PRECIO UNITARIO" optional="show" readonly="1"/>
      </xpath>

      <!-- 5) Impuestos: ocultar SIEMPRE en grilla (el PDF no los muestra como columna) -->
      <xpath expr="//field[@name='order_line']//*[self::list]//field[@name='tax_ids']" position="attributes">
        <attribute name="invisible">1</attribute>
        <attribute name="optional">hide</attribute>
      </xpath>

      <!-- 6) PRECIO TOTAL: usar subtotal (sin IVA) y renombrar 'Importe' -->
      <xpath expr="//field[@name='order_line']//*[self::list]//field[@name='price_subtotal']" position="attributes">
        <attribute name="string">PRECIO TOTAL</attribute>
        <attribute name="optional">show</attribute>
        <attribute name="sum">PRECIO TOTAL</attribute>
      </xpath>

      <!-- 7) Ocultar total con IVA (para evitar duplicados) -->
      <xpath expr="//field[@name='order_line']//*[self::list]//field[@name='price_total']" position="attributes">
        <attribute name="invisible">1</attribute>
        <attribute name="optional">hide</attribute>
      </xpath>

    </field>
  </record>
</odoo>
