<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_cer_pricing_season_list" model="ir.ui.view">
    <field name="name">cer.pricing.season.list</field>
    <field name="model">cer.pricing.season</field>
    <field name="arch" type="xml">
      <list>
        <field name="active"/>
        <field name="name"/>
        <field name="code"/>
        <field name="company_id"/>
        <field name="date_from"/>
        <field name="date_to"/>
        <field name="priority"/>
      </list>
    </field>
  </record>

  <record id="view_cer_pricing_season_calendar" model="ir.ui.view">
    <field name="name">cer.pricing.season.calendar</field>
    <field name="model">cer.pricing.season</field>
    <field name="arch" type="xml">
      <calendar string="Temporadas CER" date_start="date_from" date_stop="date_to" color="company_id">
        <field name="name"/>
        <field name="code"/>
        <field name="company_id"/>
      </calendar>
    </field>
  </record>

  <record id="view_cer_pricing_season_form" model="ir.ui.view">
    <field name="name">cer.pricing.season.form</field>
    <field name="model">cer.pricing.season</field>
    <field name="arch" type="xml">
      <form string="Temporada CER">
        <sheet>
          <group>
            <group>
              <field name="active"/>
              <field name="company_id"/>
              <field name="name"/>
              <field name="code"/>
            </group>
            <group>
              <field name="date_from"/>
              <field name="date_to"/>
              <field name="priority"/>
            </group>
          </group>
          <group>
            <field name="note" placeholder="Notas internas..."/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_cer_pricing_seasons" model="ir.actions.act_window">
    <field name="name">Temporadas</field>
    <field name="res_model">cer.pricing.season</field>
    <field name="view_mode">list,calendar,form</field>
  </record>
</odoo>
