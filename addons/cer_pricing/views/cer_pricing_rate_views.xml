<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_cer_pricing_rate_list" model="ir.ui.view">
    <field name="name">cer.pricing.rate.list</field>
    <field name="model">cer.pricing.rate</field>
    <field name="arch" type="xml">
      <list>
        <field name="active"/>
        <field name="company_id"/>
        <field name="season_id"/>
        <field name="product_tmpl_id"/>
        <field name="price"/>
        <field name="currency_id" optional="show"/>
      </list>
    </field>
  </record>

  <record id="view_cer_pricing_rate_form" model="ir.ui.view">
    <field name="name">cer.pricing.rate.form</field>
    <field name="model">cer.pricing.rate</field>
    <field name="arch" type="xml">
      <form string="Tarifa CER">
        <sheet>
          <group>
            <group>
              <field name="active"/>
              <field name="company_id"/>
              <field name="season_id"/>
            </group>
            <group>
              <field name="product_tmpl_id"/>
              <field name="price"/>
              <field name="currency_id" readonly="1"/>
            </group>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_cer_pricing_rates" model="ir.actions.act_window">
    <field name="name">Tarifas</field>
    <field name="res_model">cer.pricing.rate</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
