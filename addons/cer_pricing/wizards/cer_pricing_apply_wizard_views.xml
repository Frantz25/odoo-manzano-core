<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_cer_pricing_apply_wizard_form" model="ir.ui.view">
    <field name="name">cer.pricing.apply.wizard.form</field>
    <field name="model">cer.pricing.apply.wizard</field>
    <field name="arch" type="xml">
      <form string="Aplicar CER Pricing">
        <sheet>
          <group>
            <field name="order_id" readonly="1"/>
            <field name="date_from"/>
            <field name="date_to"/>
            <field name="participants"/>
            <field name="inclusive_days"/>
          </group>
        </sheet>
        <footer>
          <button name="action_apply" type="object" string="Aplicar" class="btn-primary"/>
          <button special="cancel" string="Cancelar" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>
