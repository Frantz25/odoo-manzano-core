<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_cer_communication_rule_list" model="ir.ui.view">
    <field name="name">cer.communication.rule.list</field>
    <field name="model">cer.communication.rule</field>
    <field name="arch" type="xml">
      <list>
        <field name="sequence"/>
        <field name="name"/>
        <field name="company_id"/>
        <field name="event_code"/>
        <field name="model_id"/>
        <field name="template_id"/>
        <field name="channel_email"/>
        <field name="channel_chatter"/>
        <field name="recipient_mode"/>
        <field name="active"/>
      </list>
    </field>
  </record>

  <record id="view_cer_communication_rule_form" model="ir.ui.view">
    <field name="name">cer.communication.rule.form</field>
    <field name="model">cer.communication.rule</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="active"/>
            <field name="sequence"/>
            <field name="name"/>
            <field name="company_id"/>
            <field name="event_code"/>
            <field name="model_id"/>
            <field name="template_id"/>
          </group>

          <group string="Canales">
            <field name="channel_email"/>
            <field name="channel_chatter"/>
            <field name="force_send"/>
          </group>

          <group string="Destinatarios">
            <field name="recipient_mode"/>
            <field name="custom_emails"/>
            <field name="extra_partner_ids" widget="many2many_tags"/>
          </group>

          <group>
            <field name="note"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_cer_communication_rule" model="ir.actions.act_window">
    <field name="name">Reglas de Comunicación</field>
    <field name="res_model">cer.communication.rule</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
