    <record id="rule_booking_reserved_customer" model="cer.communication.rule">
      <field name="name">Booking reservada → Cliente</field>
      <field name="company_id" eval="ref('base.main_company')"/>
      <field name="model_id" ref="sale.model_sale_order"/>
      <field name="event_code">booking_reserved</field>
      <field name="template_id" ref="cer_communications.mail_template_cer_booking_reserved"/>
      <field name="recipient_mode">customer</field>
      <field name="channel_email" eval="True"/>
      <field name="channel_chatter" eval="True"/>
      <field name="sequence">10</field>
    </record>

