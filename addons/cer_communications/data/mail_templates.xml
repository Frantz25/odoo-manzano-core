<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">

    <record id="mail_template_cer_booking_reserved" model="mail.template">
      <field name="name">CER - Reserva reservada</field>
      <field name="model_id" ref="sale.model_sale_order"/>
      <field name="subject">Reserva reservada: ${object.name}</field>
      <field name="body_html"><![CDATA[
        <div>
          <p>Hola,</p>
          <p>Tu reserva ha sido <strong>reservada</strong>.</p>
          <ul>
            <li><strong>Referencia</strong>: ${object.cer_booking_name or object.name}</li>
            <li><strong>Entrada</strong>: ${object.cer_date_from or ''}</li>
            <li><strong>Salida</strong>: ${object.cer_date_to or ''}</li>
            <li><strong>Código de acceso</strong>: ${object.cer_booking_offline_code or ''}</li>
          </ul>
          <p>Gracias.</p>
        </div>
      ]]></field>
    </record>

    <record id="mail_template_cer_booking_confirmed" model="mail.template">
      <field name="name">CER - Reserva confirmada (cliente)</field>
      <field name="model_id" ref="sale.model_sale_order"/>
      <field name="subject">Reserva confirmada: ${object.name}</field>
      <field name="body_html"><![CDATA[
        <div>
          <p>Hola,</p>
          <p>Tu reserva ha sido <strong>confirmada</strong>.</p>
          <ul>
            <li><strong>Referencia</strong>: ${object.cer_booking_name or object.name}</li>
            <li><strong>Entrada</strong>: ${object.cer_date_from or ''}</li>
            <li><strong>Salida</strong>: ${object.cer_date_to or ''}</li>
            <li><strong>Código de acceso</strong>: ${object.cer_booking_offline_code or ''}</li>
          </ul>
        </div>
      ]]></field>
    </record>

    <record id="mail_template_cer_booking_confirmed_internal" model="mail.template">
      <field name="name">CER - Reserva confirmada (interno)</field>
      <field name="model_id" ref="sale.model_sale_order"/>
      <field name="subject">[Interno] Reserva confirmada: ${object.name}</field>
      <field name="body_html"><![CDATA[
        <div>
          <p>Reserva <strong>confirmada</strong> para seguimiento interno.</p>
          <ul>
            <li><strong>Cliente</strong>: ${object.partner_id.name or ''}</li>
            <li><strong>Referencia</strong>: ${object.name}</li>
            <li><strong>Reserva</strong>: ${object.cer_booking_name or ''}</li>
            <li><strong>Entrada</strong>: ${object.cer_date_from or ''}</li>
            <li><strong>Salida</strong>: ${object.cer_date_to or ''}</li>
            <li><strong>Participantes</strong>: ${object.cer_participants or 0}</li>
            <li><strong>Total</strong>: ${format_amount(object.amount_total, object.currency_id)}</li>
          </ul>
        </div>
      ]]></field>
    </record>

    <record id="mail_template_cer_booking_checkin_pass" model="mail.template">
      <field name="name">CER - Pase individual check-in</field>
      <field name="model_id" ref="sale.model_sale_order"/>
      <field name="subject">Tu pase de check-in CER: ${object.name}</field>
      <field name="body_html"><![CDATA[
        <div>
          <p>Hola ${object.partner_id.name or ''},</p>
          <p>Te compartimos tu pase de check-in.</p>
          <ul>
            <li><strong>Reserva</strong>: ${object.cer_booking_name or object.name}</li>
            <li><strong>Entrada</strong>: ${object.cer_date_from or ''}</li>
            <li><strong>Salida</strong>: ${object.cer_date_to or ''}</li>
            <li><strong>Código de acceso</strong>: ${object.cer_booking_offline_code or ''}</li>
          </ul>
          <p>
            <img src="${object.cer_checkin_qr_img_url or ''}" alt="QR Check-in" style="max-width:220px;max-height:220px;"/>
          </p>
          <p>
            Enlace directo check-in:<br/>
            <a href="${object.cer_booking_qr_url or '#'}">${object.cer_booking_qr_url or ''}</a>
          </p>
          <p>Presenta este código QR en recepción.</p>
        </div>
      ]]></field>
    </record>

    <record id="mail_template_cer_booking_cancelled" model="mail.template">
      <field name="name">CER - Reserva cancelada</field>
      <field name="model_id" ref="sale.model_sale_order"/>
      <field name="subject">Reserva cancelada: ${object.name}</field>
      <field name="body_html"><![CDATA[
        <div>
          <p>Hola,</p>
          <p>Tu reserva ha sido <strong>cancelada</strong>.</p>
          <ul>
            <li><strong>Referencia</strong>: ${object.name}</li>
            <li><strong>Entrada</strong>: ${object.cer_date_from or ''}</li>
            <li><strong>Salida</strong>: ${object.cer_date_to or ''}</li>
          </ul>
        </div>
      ]]></field>
    </record>

    <record id="mail_template_cer_booking_reserved_internal" model="mail.template">
      <field name="name">CER - Reserva reservada (interno)</field>
      <field name="model_id" ref="sale.model_sale_order"/>
      <field name="subject">[Interno] Reserva reservada: ${object.name}</field>
      <field name="body_html"><![CDATA[
        <div>
          <p>Reserva en estado <strong>reservada</strong>.</p>
          <ul>
            <li><strong>Cliente</strong>: ${object.partner_id.name or ''}</li>
            <li><strong>Reserva</strong>: ${object.cer_booking_name or object.name}</li>
            <li><strong>Entrada</strong>: ${object.cer_date_from or ''}</li>
            <li><strong>Salida</strong>: ${object.cer_date_to or ''}</li>
            <li><strong>Participantes</strong>: ${object.cer_participants or 0}</li>
          </ul>
        </div>
      ]]></field>
    </record>

    <record id="mail_template_cer_booking_cancelled_internal" model="mail.template">
      <field name="name">CER - Reserva cancelada (interno)</field>
      <field name="model_id" ref="sale.model_sale_order"/>
      <field name="subject">[Interno] Reserva cancelada: ${object.name}</field>
      <field name="body_html"><![CDATA[
        <div>
          <p>Reserva <strong>cancelada</strong> para seguimiento interno.</p>
          <ul>
            <li><strong>Cliente</strong>: ${object.partner_id.name or ''}</li>
            <li><strong>Reserva</strong>: ${object.cer_booking_name or object.name}</li>
            <li><strong>Entrada</strong>: ${object.cer_date_from or ''}</li>
            <li><strong>Salida</strong>: ${object.cer_date_to or ''}</li>
            <li><strong>Total</strong>: ${format_amount(object.amount_total, object.currency_id)}</li>
          </ul>
        </div>
      ]]></field>
    </record>

    <record id="mail_template_cer_sale_validity_reminder" model="mail.template">
      <field name="name">CER - Recordatorio vigencia cotización</field>
      <field name="model_id" ref="sale.model_sale_order"/>
      <field name="subject">Recordatorio: vigencia de tu cotización ${object.name}</field>
      <field name="body_html"><![CDATA[
        <div>
          <p>Hola,</p>
          <p>Te recordamos que la cotización <strong>${object.name}</strong> vence el <strong>${object.validity_date or ''}</strong>.</p>
          <p>Total: <strong>${format_amount(object.amount_total, object.currency_id)}</strong></p>
        </div>
      ]]></field>
    </record>

    <record id="mail_template_cer_precheckin_reminder" model="mail.template">
      <field name="name">CER - Recordatorio pre check-in</field>
      <field name="model_id" ref="sale.model_sale_order"/>
      <field name="subject">Recordatorio de llegada: ${object.cer_booking_name or object.name}</field>
      <field name="body_html"><![CDATA[
        <div>
          <p>Hola ${object.partner_id.name or ''},</p>
          <p>Te recordamos tu check-in próximo.</p>
          <ul>
            <li><strong>Reserva</strong>: ${object.cer_booking_name or object.name}</li>
            <li><strong>Entrada</strong>: ${object.cer_date_from or ''}</li>
            <li><strong>Salida</strong>: ${object.cer_date_to or ''}</li>
            <li><strong>Código de acceso</strong>: ${object.cer_booking_offline_code or ''}</li>
          </ul>
          <p>
            <img src="${object.cer_checkin_qr_img_url or ''}" alt="QR Check-in" style="max-width:220px;max-height:220px;"/>
          </p>
          <p>
            Enlace directo check-in:<br/>
            <a href="${object.cer_booking_qr_url or '#'}">${object.cer_booking_qr_url or ''}</a>
          </p>
        </div>
      ]]></field>
    </record>

    <record id="mail_template_cer_postevent_followup" model="mail.template">
      <field name="name">CER - Gracias por tu visita</field>
      <field name="model_id" ref="sale.model_sale_order"/>
      <field name="subject">Gracias por tu visita a CER (${object.cer_booking_name or object.name})</field>
      <field name="body_html"><![CDATA[
        <div>
          <p>Hola ${object.partner_id.name or ''},</p>
          <p>Gracias por elegir Centro de Entrenamiento y Recreación El Manzano.</p>
          <p>Nos encantaría conocer tu experiencia y sugerencias para seguir mejorando.</p>
          <ul>
            <li><strong>Reserva</strong>: ${object.cer_booking_name or object.name}</li>
            <li><strong>Estadía</strong>: ${object.cer_date_from or ''} al ${object.cer_date_to or ''}</li>
          </ul>
          <p>Si quieres, responde este correo con tu evaluación o completa nuestro formulario interno de feedback.</p>
        </div>
      ]]></field>
    </record>

    <record id="mail_template_cer_catalog_sync_failed" model="mail.template">
      <field name="name">CER - Catálogo sync falló</field>
      <field name="model_id" ref="cer_catalog_github.model_cer_catalog_sync_log"/>
      <field name="subject">Catálogo CER: Sync falló (${object.company_id.name})</field>
      <field name="body_html"><![CDATA[
        <div>
          <p>Sync de catálogo <strong>falló</strong>.</p>
          <ul>
            <li><strong>Fuente</strong>: ${object.source_id.name if object.source_id else ''}</li>
            <li><strong>Archivo</strong>: ${object.filename or ''}</li>
            <li><strong>URL</strong>: ${object.url or ''}</li>
            <li><strong>Error</strong>: ${object.error_message or ''}</li>
          </ul>
        </div>
      ]]></field>
    </record>

    <record id="mail_template_cer_catalog_sync_success" model="mail.template">
      <field name="name">CER - Catálogo sync OK</field>
      <field name="model_id" ref="cer_catalog_github.model_cer_catalog_sync_log"/>
      <field name="subject">Catálogo CER: Sync OK (${object.company_id.name})</field>
      <field name="body_html"><![CDATA[
        <div>
          <p>Sync de catálogo <strong>exitoso</strong>.</p>
          <ul>
            <li><strong>Fuente</strong>: ${object.source_id.name if object.source_id else ''}</li>
            <li><strong>Archivo</strong>: ${object.filename or ''}</li>
            <li><strong>Creados</strong>: ${object.created_count or 0}</li>
            <li><strong>Actualizados</strong>: ${object.updated_count or 0}</li>
            <li><strong>Omitidos</strong>: ${object.skipped_count or 0}</li>
          </ul>
        </div>
      ]]></field>
    </record>

    <record id="mail_template_cer_document_finalized" model="mail.template">
      <field name="name">CER - Documento finalizado</field>
      <field name="model_id" ref="cer_documents.model_cer_document"/>
      <field name="subject">Documento CER finalizado: ${object.name}</field>
      <field name="body_html"><![CDATA[
        <div>
          <p>Documento CER <strong>finalizado</strong>.</p>
          <ul>
            <li><strong>Documento</strong>: ${object.name}</li>
            <li><strong>Plantilla</strong>: ${object.template_id.name if object.template_id else ''}</li>
            <li><strong>Origen</strong>: ${object.res_model or ''} / ${object.res_id or ''}</li>
          </ul>
        </div>
      ]]></field>
    </record>

  </data>
</odoo>
