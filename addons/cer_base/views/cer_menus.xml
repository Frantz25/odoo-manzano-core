<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="action_cer_config_settings" model="ir.actions.act_window">
    <field name="name">Configuración CER</field>
    <field name="res_model">res.config.settings</field>
    <field name="view_mode">form</field>
    <field name="target">current</field>
    <field name="context">{'module': 'cer_base'}</field>
  </record>

  <menuitem id="menu_cer_root"
            name="CER"
            sequence="10"
            groups="cer_base.group_cer_user"/>

  <menuitem id="menu_cer_configuration"
            name="Configuración"
            parent="cer_base.menu_cer_root"
            sequence="90"
            groups="base.group_system"/>

  <menuitem id="menu_cer_settings"
            name="Parámetros CER"
            parent="cer_base.menu_cer_configuration"
            action="cer_base.action_cer_config_settings"
            sequence="10"
            groups="base.group_system"/>

</odoo>

