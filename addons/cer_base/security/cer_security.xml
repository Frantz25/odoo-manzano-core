<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="0">

    <record id="module_category_cer" model="ir.module.category">
      <field name="name">CER</field>
      <field name="description">Permisos CER</field>
      <field name="sequence">10</field>
    </record>

    <!-- Odoo 19: agrupación por privilegios (privilege_id) -->
    <record id="privilege_cer" model="res.groups.privilege">
      <field name="name">CER</field>
      <field name="sequence">10</field>
      <field name="category_id" ref="cer_base.module_category_cer"/>
    </record>

    <record id="group_cer_user" model="res.groups">
      <field name="name">CER / Usuario</field>
      <field name="privilege_id" ref="cer_base.privilege_cer"/>
      <field name="comment">Acceso base a funcionalidades CER.</field>
      <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_cer_manager" model="res.groups">
      <field name="name">CER / Manager</field>
      <field name="privilege_id" ref="cer_base.privilege_cer"/>
      <field name="comment">Gestión operativa CER (sin privilegios de sistema).</field>
      <field name="implied_ids" eval="[(4, ref('cer_base.group_cer_user'))]"/>
    </record>

    <record id="group_cer_admin" model="res.groups">
      <field name="name">CER / Admin</field>
      <field name="privilege_id" ref="cer_base.privilege_cer"/>
      <field name="comment">Administración CER (sin otorgar Settings globales automáticamente).</field>
      <field name="implied_ids" eval="[(4, ref('cer_base.group_cer_manager'))]"/>
    </record>

  </data>
</odoo>

