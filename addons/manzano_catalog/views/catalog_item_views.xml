<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_manzano_catalog_item_tree" model="ir.ui.view">
    <field name="name">manzano.catalog.item.tree</field>
    <field name="model">manzano.catalog.item</field>
    <field name="arch" type="xml">
      <list string="Catalog Items">
        <field name="external_ref"/>
        <field name="name"/>
        <field name="category"/>
        <field name="unit_type"/>
        <field name="capacity_units"/>
        <field name="price_base"/>
        <field name="currency"/>
        <field name="active"/>
        <field name="last_sync_at"/>
      </list>
    </field>
  </record>

  <record id="view_manzano_catalog_item_form" model="ir.ui.view">
    <field name="name">manzano.catalog.item.form</field>
    <field name="model">manzano.catalog.item</field>
    <field name="arch" type="xml">
      <form string="Catalog Item">
        <sheet>
          <group>
            <field name="external_ref"/>
            <field name="name"/>
            <field name="category"/>
            <field name="unit_type"/>
            <field name="capacity_units"/>
            <field name="price_base"/>
            <field name="currency"/>
            <field name="active"/>
          </group>
          <group>
            <field name="source_name" readonly="1"/>
            <field name="source_hash" readonly="1"/>
            <field name="last_sync_at" readonly="1"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_manzano_catalog_items" model="ir.actions.act_window">
    <field name="name">Catalog Items</field>
    <field name="res_model">manzano.catalog.item</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
