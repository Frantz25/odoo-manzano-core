<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="product_template_form_inherit_cer_booking" model="ir.ui.view">
    <field name="name">product.template.form.inherit.cer.booking</field>
    <field name="model">product.template</field>
    <field name="inherit_id" ref="product.product_template_only_form_view"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet//group" position="after">
        <group string="CER Reserva">
          <field name="cer_reservable"/>
          <field name="cer_unit_type" invisible="not cer_reservable"/>
          <field name="cer_capacity_units" invisible="not cer_reservable"/>
        </group>
      </xpath>
    </field>
  </record>
</odoo>
