<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_order_form_manzano_catalog_integration" model="ir.ui.view">
    <field name="name">sale.order.form.manzano.catalog.integration</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='order_line']/list/field[@name='name']" position="before">
        <field name="mz_catalog_item_id"/>
      </xpath>
    </field>
  </record>
</odoo>
