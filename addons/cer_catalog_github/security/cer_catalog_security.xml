<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="rule_cer_catalog_source_company" model="ir.rule">
      <field name="name">CER Catalog Source multi-company</field>
      <field name="model_id" ref="model_cer_catalog_source"/>
      <field name="domain_force">[('company_id','in',company_ids)]</field>
      <field name="groups" eval="[(4, ref('cer_base.group_cer_user'))]"/>
    </record>

    <record id="rule_cer_catalog_log_company" model="ir.rule">
      <field name="name">CER Catalog Sync Log multi-company</field>
      <field name="model_id" ref="model_cer_catalog_sync_log"/>
      <field name="domain_force">[('company_id','in',company_ids)]</field>
      <field name="groups" eval="[(4, ref('cer_base.group_cer_user'))]"/>
    </record>

  </data>
</odoo>
