<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_cer_catalog_sync_log_list" model="ir.ui.view">
    <field name="name">cer.catalog.sync.log.list</field>
    <field name="model">cer.catalog.sync.log</field>
    <field name="arch" type="xml">
      <list>
        <field name="create_date"/>
        <field name="company_id"/>
        <field name="source_id"/>
        <field name="state"/>
        <field name="initiated_by"/>
        <field name="created_count"/>
        <field name="updated_count"/>
        <field name="skipped_count"/>
        <field name="duration_ms" optional="show"/>
        <field name="filename" optional="show"/>
      </list>
    </field>
  </record>

  <record id="view_cer_catalog_sync_log_form" model="ir.ui.view">
    <field name="name">cer.catalog.sync.log.form</field>
    <field name="model">cer.catalog.sync.log</field>
    <field name="arch" type="xml">
      <form string="Log Sync Catálogo CER" create="0" edit="0">
        <sheet>
          <group>
            <field name="name"/>
            <field name="company_id"/>
            <field name="source_id"/>
          </group>
          <group>
            <field name="state"/>
            <field name="initiated_by"/>
            <field name="started_at"/>
            <field name="finished_at"/>
            <field name="duration_ms"/>
          </group>
          <group>
            <field name="created_count"/>
            <field name="updated_count"/>
            <field name="skipped_count"/>
          </group>

          <notebook>
            <page string="Detalles">
              <group>
                <field name="url"/>
                <field name="filename"/>
              </group>
              <field name="message"/>
            </page>
            <page string="Errores">
              <field name="error_message"/>
              <field name="error_trace"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_cer_catalog_sync_logs" model="ir.actions.act_window">
    <field name="name">Logs de sincronización</field>
    <field name="res_model">cer.catalog.sync.log</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
