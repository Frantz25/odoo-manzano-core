<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="report_cer_document">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="doc">
        <t t-call="web.external_layout">
          <div class="page">
          <div style="display:flex;align-items:center;justify-content:flex-end;margin-bottom:10px;">
            <div style="text-align:right;">
              <h3 style="margin:0;" t-esc="doc.name"/>
              <p class="text-muted" style="margin:0;">
                <span t-esc="doc.number"/> - <span t-esc="doc.create_date"/>
              </p>
            </div>
          </div>

          <t t-set="origin" t-value="env[doc.res_model].browse(doc.res_id) if doc.res_model and doc.res_id else False"/>

          <t t-if="origin and doc.res_model == 'sale.order'">
          <h4 style="margin-top:8px;">Resumen de Reserva</h4>
          <table style="width:100%; margin-bottom:12px; border-collapse:collapse;">
            <tr>
              <td><strong>Cliente:</strong> <span t-esc="origin.partner_id.display_name"/></td>
              <td><strong>Orden:</strong> <span t-esc="origin.name"/></td>
            </tr>
            <tr>
              <td><strong>Entrada:</strong> <span t-esc="origin.cer_date_from or '-'"/></td>
              <td><strong>Salida:</strong> <span t-esc="origin.cer_date_to or '-'"/></td>
            </tr>
            <tr>
              <td><strong>Estadía:</strong> <span t-esc="origin.cer_stay_days or 0"/> día(s)</td>
              <td><strong>Participantes:</strong> <span t-esc="origin.cer_participants or 0"/></td>
            </tr>
          </table>

          <h4>Detalle</h4>
          <table class="table table-sm" style="width:100%; border-collapse:collapse;">
            <thead>
              <tr>
                <th style="text-align:left;">Producto</th>
                <th style="text-align:right;">Cantidad</th>
                <th style="text-align:right;">Precio Unit.</th>
                <th style="text-align:right;">Subtotal</th>
              </tr>
            </thead>
            <tbody>
              <tr t-foreach="origin.order_line.filtered(lambda l: not l.display_type)" t-as="line">
                <td><span t-esc="line.product_id.name"/></td>
                <td style="text-align:right;"><span t-esc="line.product_uom_qty"/></td>
                <td style="text-align:right;"><span t-esc="line.price_unit"/></td>
                <td style="text-align:right;"><span t-esc="line.price_subtotal"/></td>
              </tr>
            </tbody>
          </table>

          <table style="width:40%; margin-left:auto; margin-top:10px;">
            <tr><td><strong>Neto</strong></td><td style="text-align:right;"><span t-esc="origin.amount_untaxed"/></td></tr>
            <tr><td><strong>IVA</strong></td><td style="text-align:right;"><span t-esc="origin.amount_tax"/></td></tr>
            <tr><td><strong>Total</strong></td><td style="text-align:right;"><span t-esc="origin.amount_total"/></td></tr>
          </table>

          <div style="margin-top:18px; border-top:1px solid #ddd; padding-top:12px;">
            <h4 style="margin-bottom:8px;">Check-in Reserva</h4>
            <t t-if="origin.cer_booking_qr_url">
              <div t-raw="origin.cer_booking_qr_html or ''"/>
              <p style="margin-top:6px; font-size:12px;">
                <strong>URL check-in:</strong>
                <span t-esc="origin.cer_booking_qr_url"/>
              </p>
              <p style="margin-top:2px; font-size:12px;" t-if="origin.cer_booking_offline_code">
                <strong>Código offline:</strong>
                <span t-esc="origin.cer_booking_offline_code"/>
              </p>
            </t>
            <t t-else="">
              <p class="text-muted">Reserva sin QR disponible aún. Confirma la reserva para habilitar check-in.</p>
            </t>
          </div>
        </t>

        <t t-if="not (origin and doc.res_model == 'sale.order')">
          <div t-raw="doc.html_content or ''"/>
        </t>

        <div style="margin-top:24px; border-top:1px solid #ddd; padding-top:10px;" t-if="doc.signature_image or doc.signature_signer_name">
          <h4 style="margin-bottom:8px;">Firma</h4>
          <div t-if="doc.signature_image">
            <img t-att-src="image_data_uri(doc.signature_image)" alt="Firma" style="max-height:90px;"/>
          </div>
          <p style="margin-top:6px;" t-if="doc.signature_signer_name"><strong>Firmante:</strong> <span t-esc="doc.signature_signer_name"/></p>
          <p style="margin-top:2px;" t-if="doc.signature_signed_at"><strong>Fecha firma:</strong> <span t-esc="doc.signature_signed_at"/></p>
        </div>
          </div>
        </t>
      </t>
    </t>
  </template>

  <record id="action_report_cer_document" model="ir.actions.report">
    <field name="name">Documento CER</field>
    <field name="model">cer.document</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">cer_documents.report_cer_document</field>
    <field name="report_file">cer_documents.report_cer_document</field>
    <field name="print_report_name">'%s' % (object.number or object.name)</field>
  </record>
</odoo>
