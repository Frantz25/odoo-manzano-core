<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_cer_document_create_wizard_form" model="ir.ui.view">
    <field name="name">cer.document.create.wizard.form</field>
    <field name="model">cer.document.create.wizard</field>
    <field name="arch" type="xml">
      <form string="Creador Documento CER">
        <group>
          <field name="template_id" options="{'no_create': True}" required="1"
                 domain="[('active','=',True), ('model_id.model','=',res_model)]"/>
          <field name="res_model" invisible="1"/>
          <field name="res_id" invisible="1"/>
        </group>
        <footer>
          <button name="action_create_document" type="object" string="Crear documento" class="btn-primary"/>
          <button string="Cancelar" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>
