<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="sale_order_form_inherit_cer_documents" model="ir.ui.view">
    <field name="name">sale.order.form.inherit.cer.documents</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">

      <!-- Smart buttons -->
      <xpath expr="//sheet//div[hasclass('oe_button_box')]" position="inside">
        <button name="action_view_cer_documents" type="object" class="oe_stat_button" icon="fa-file-text-o">
          <field name="cer_document_count" widget="statinfo" string="Documentos"/>
        </button>
      </xpath>

      <!-- Header button -->
      <xpath expr="//header" position="inside">
        <button name="action_open_cer_reservation_confirmation_wizard"
                type="object"
                string="Confirmación Reserva"
                class="btn-secondary"
                invisible="not cer_is_booking or cer_booking_state not in ('reserved','confirmed')"/>
        <button name="action_open_cer_checkin_pass_wizard"
                type="object"
                string="Check-in Pass"
                class="btn-secondary"
                invisible="not cer_is_booking or cer_booking_state != 'confirmed'"/>
        <button name="action_open_cer_acta_create_wizard"
                type="object"
                string="Crear Acta CER"
                class="btn-secondary"
                invisible="not cer_is_booking or cer_booking_state not in ('reserved','confirmed')"/>
      </xpath>

    </field>
  </record>
</odoo>
